{
  "redirects": [
    {
      "source": "/compound-interest",
      "destination": "/compound-interest-calculator",
      "permanent": true
    },
    {
      "source": "/retirement-calculator",
      "destination": "/retirement-savings-calculator",
      "permanent": true
    },
    {
      "source": "/loan-calculator",
      "destination": "/loan-amortization-calculator",
      "permanent": true
    },
    {
      "source": "/apr-ear",
      "destination": "/apr-to-ear-calculator",
      "permanent": true
    },
    {
      "source": "/savings-calculator",
      "destination": "/savings-goal-calculator",
      "permanent": true
    },
    {
      "source": "/inflation",
      "destination": "/inflation-calculator",
      "permanent": true
    },
    {
      "source": "/cd-ladder",
      "destination": "/cd-ladder-calculator",
      "permanent": true
    },
    {
      "source": "/tax-calculator",
      "destination": "/us-tax-calculator",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400" }
      ]
    }
  ]
}
